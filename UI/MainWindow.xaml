<Window x:Class="DL_Skin_Randomiser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DL_Skin_Randomiser"
        mc:Ignorable="d"
        Title="Deadlock Skin Randomiser" Height="720" Width="1120"
        Background="#111111">
    <DockPanel Margin="18">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="RandomiseButton"
                    Width="140"
                    Margin="0,0,8,0"
                    Click="RandomiseButton_Click"
                    Content="Randomise" />
            <Button x:Name="ApplyButton"
                    Width="140"
                    Margin="0,0,8,0"
                    Click="ApplyButton_Click"
                    Content="Apply to DLMM" />
            <Button x:Name="ReloadButton"
                    Width="100"
                    Margin="0,0,12,0"
                    Click="ReloadButton_Click"
                    Content="Reload" />
            <Button x:Name="BrowseDlmmButton"
                    Width="130"
                    Margin="0,0,12,0"
                    Click="BrowseDlmmButton_Click"
                    Content="DLMM state..." />
            <TextBox x:Name="NewFolderTextBox"
                     Width="150"
                     Margin="0,0,6,0"
                     VerticalContentAlignment="Center"
                     Background="White"
                     Foreground="#111111" />
            <Button x:Name="AddFolderButton"
                    Width="90"
                    Margin="0,0,12,0"
                    Click="AddFolderButton_Click"
                    Content="Add folder" />
            <TextBlock Text="Character"
                       VerticalAlignment="Center"
                       Foreground="#CFCFCF"
                       Margin="0,0,6,0" />
            <ComboBox x:Name="CharacterFilterBox"
                      Width="180"
                      Margin="0,0,12,0"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      StaysOpenOnEdit="True"
                      SelectionChanged="CharacterFilterBox_SelectionChanged"
                      DropDownClosed="CharacterFilterBox_DropDownClosed"
                      KeyUp="CharacterFilterBox_KeyUp"
                      Background="White"
                      Foreground="#111111" />
            <TextBlock Text="Folder"
                       VerticalAlignment="Center"
                       Foreground="#CFCFCF"
                       Margin="0,0,6,0" />
            <ComboBox x:Name="FolderFilterBox"
                      Width="170"
                      Margin="0,0,12,0"
                      IsEditable="True"
                      IsTextSearchEnabled="True"
                      StaysOpenOnEdit="True"
                      SelectionChanged="FolderFilterBox_SelectionChanged"
                      DropDownClosed="FolderFilterBox_DropDownClosed"
                      KeyUp="FolderFilterBox_KeyUp"
                      Background="White"
                      Foreground="#111111" />
            <TextBlock x:Name="StatusText"
                       VerticalAlignment="Center"
                       Foreground="#E6E6E6" />
        </StackPanel>

        <ScrollViewer x:Name="MainScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel">
            <ItemsControl x:Name="HeroGroupsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="True" Margin="0,0,0,14">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayHero}"
                                               Foreground="#F4F4F4"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Mods.Count, StringFormat='  {0} mods'}"
                                               Foreground="#BDBDBD"
                                               Margin="10,2,0,0" />
                                    <TextBlock Text="{Binding EnabledCount, StringFormat='  {0} enabled'}"
                                               Foreground="#91D18B"
                                               Margin="10,2,0,0" />
                                    <TextBlock Text="{Binding IncludedCount, StringFormat='  {0} included'}"
                                               Foreground="#D5B56E"
                                               Margin="10,2,0,0" />
                                </StackPanel>
                            </Expander.Header>

                            <Border Background="#1B1B1B"
                                    BorderBrush="#303030"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,8,0,0">
                                <Grid>
                                    <TextBlock Text="{Binding BackgroundHero}"
                                               FontSize="64"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Opacity="0.08"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Top"
                                               IsHitTestVisible="False" />

                                    <ItemsControl ItemsSource="{Binding Mods}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="210"
                                                        Height="340"
                                                        Margin="0,0,14,14"
                                                        Background="#242424"
                                                        BorderBrush="#3B3B3B"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="120" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0"
                                                                Background="#151515"
                                                                CornerRadius="8,8,0,0"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <Image Source="{Binding ImageUrl}"
                                                                       Stretch="UniformToFill"
                                                                       Opacity="0.92" />
                                                            </Grid>
                                                        </Border>

                                                        <Grid Grid.Row="1" Margin="10">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel Grid.Row="0">
                                                                <TextBlock Text="{Binding Name}"
                                                                           Foreground="#F2F2F2"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="Wrap"
                                                                           MaxHeight="44" />
                                                                <TextBlock Text="{Binding Category}"
                                                                           Foreground="#B7B7B7"
                                                                           Margin="0,4,0,8" />
                                                                <CheckBox Content="Include in randomiser"
                                                                          IsChecked="{Binding IncludedInRandomizer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          Checked="ModPreference_Changed"
                                                                          Unchecked="ModPreference_Changed"
                                                                          Foreground="#EDEDED"
                                                                          Margin="0,0,0,4" />
                                                                <CheckBox Content="Enabled in DLMM"
                                                                          IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          Checked="ModPreference_Changed"
                                                                          Unchecked="ModPreference_Changed"
                                                                          Foreground="#EDEDED" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                                                <TextBlock Text="Character"
                                                                           Foreground="#AFAFAF"
                                                                           Margin="0,0,0,3" />
                                                                <ComboBox SelectedValue="{Binding Hero, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          ItemsSource="{Binding CharacterOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          DisplayMemberPath="Name"
                                                                          SelectedValuePath="Key"
                                                                          TextSearch.TextPath="Name"
                                                                          IsEditable="False"
                                                                          IsTextSearchEnabled="True"
                                                                          SelectionChanged="CharacterSelector_SelectionChanged"
                                                                          Padding="4,2"
                                                                          Background="White"
                                                                          Foreground="#111111"
                                                                          BorderBrush="#4A4A4A">
                                                                    <ComboBox.ItemContainerStyle>
                                                                        <Style TargetType="ComboBoxItem">
                                                                            <Setter Property="Foreground" Value="#111111" />
                                                                            <Setter Property="Background" Value="White" />
                                                                            <Setter Property="Padding" Value="8,4" />
                                                                        </Style>
                                                                    </ComboBox.ItemContainerStyle>
                                                                </ComboBox>
                                                                <TextBlock Text="Folder"
                                                                           Foreground="#AFAFAF"
                                                                           Margin="0,8,0,3" />
                                                                <ComboBox Text="{Binding FolderDisplay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          ItemsSource="{Binding FolderOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          IsEditable="True"
                                                                          IsTextSearchEnabled="True"
                                                                          StaysOpenOnEdit="True"
                                                                          LostKeyboardFocus="FolderSelector_LostKeyboardFocus"
                                                                          SelectionChanged="FolderSelector_SelectionChanged"
                                                                          Padding="4,2"
                                                                          Background="White"
                                                                          Foreground="#111111"
                                                                          BorderBrush="#4A4A4A">
                                                                    <ComboBox.ItemContainerStyle>
                                                                        <Style TargetType="ComboBoxItem">
                                                                            <Setter Property="Foreground" Value="#111111" />
                                                                            <Setter Property="Background" Value="White" />
                                                                            <Setter Property="Padding" Value="8,4" />
                                                                        </Style>
                                                                    </ComboBox.ItemContainerStyle>
                                                                </ComboBox>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
