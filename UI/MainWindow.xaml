<Window x:Class="DL_Skin_Randomiser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DL_Skin_Randomiser"
        mc:Ignorable="d"
        Title="Deadlock Skin Randomiser" Height="760" Width="1180"
        Background="#0F1011"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Background" Value="#242628" />
            <Setter Property="Foreground" Value="#F3F3F3" />
            <Setter Property="BorderBrush" Value="#3A3D40" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#303438" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#656B70" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#1F2224" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#D9F3A7" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#D9F3A7" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="BorderBrush" Value="#D9F3A7" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MaxDropDownHeight" Value="280" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Background" Value="#F5F5F5" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#111111" />
                        <Setter Property="Background" Value="#FFFFFF" />
                        <Setter Property="Padding" Value="8,5" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#111111" />
                                <Setter Property="Background" Value="#D9F3A7" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Foreground" Value="#111111" />
                                <Setter Property="Background" Value="#D9F3A7" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#111111" />
                                <Setter Property="Background" Value="#C6E990" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="7,4" />
            <Setter Property="Background" Value="#F5F5F5" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="BorderBrush" Value="#D8D8D8" />
        </Style>
        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AEB4B8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F4F4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="TopPanel" TargetType="Border">
            <Setter Property="Background" Value="#1D2022" />
            <Setter Property="BorderBrush" Value="#34383C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,10,10" />
        </Style>
    </Window.Resources>
    <DockPanel Margin="18">
        <Border DockPanel.Dock="Top"
                Background="#17191B"
                BorderBrush="#2B2E31"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16"
                Margin="0,0,0,12">
            <StackPanel>
                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Deadlock Skin Randomiser"
                                   Foreground="#F7F7F7"
                                   FontSize="22"
                                   FontWeight="Bold" />
                        <TextBlock Text="Pick a profile, choose your skins, apply, then play."
                                   Foreground="#9EA5AA"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="#202326"
                            BorderBrush="#34383C"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="TrayStatusDot"
                                     Width="10"
                                     Height="10"
                                     Fill="#91D18B"
                                     VerticalAlignment="Center"
                                     Margin="0,0,10,0" />
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="NoticeTitleText"
                                           Text="Ready"
                                           Foreground="#F3F3F3"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="StatusText"
                                           Text="Load a profile to begin."
                                           Foreground="#AEB4B8"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <WrapPanel>
                    <Border Style="{StaticResource TopPanel}" MinWidth="430">
                        <StackPanel>
                            <TextBlock Text="Session" Style="{StaticResource PanelTitle}" />
                            <WrapPanel>
                                <Button x:Name="RandomisePlayButton"
                                        Width="158"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="RandomisePlayButton_Click"
                                        Content="Randomise &amp; Play" />
                                <Button x:Name="RandomiseButton"
                                        Width="128"
                                        Click="RandomiseButton_Click"
                                        Content="Randomise" />
                                <Button x:Name="ApplyButton"
                                        Width="104"
                                        Click="ApplyButton_Click"
                                        Content="Apply" />
                                <Button x:Name="ReloadButton"
                                        Width="104"
                                        Click="ReloadButton_Click"
                                        Content="Reload" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource TopPanel}" MinWidth="430">
                        <StackPanel>
                            <TextBlock Text="Folders" Style="{StaticResource PanelTitle}" />
                            <WrapPanel>
                                <TextBox x:Name="NewFolderTextBox"
                                         Width="180"
                                         Margin="0,0,8,8"
                                         VerticalContentAlignment="Center" />
                                <Button x:Name="AddFolderButton"
                                        Width="104"
                                        Click="AddFolderButton_Click"
                                        Content="Add folder" />
                                <Button x:Name="RemoveFolderButton"
                                        Width="124"
                                        Click="RemoveFolderButton_Click"
                                        Content="Remove folder" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource TopPanel}" MinWidth="170">
                        <StackPanel>
                            <TextBlock Text="Source" Style="{StaticResource PanelTitle}" />
                            <Button x:Name="BrowseDlmmButton"
                                    Width="128"
                                    Click="BrowseDlmmButton_Click"
                                    Content="DLMM state" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource TopPanel}">
                        <StackPanel>
                            <TextBlock Text="Filters" Style="{StaticResource PanelTitle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Search mods" Style="{StaticResource FilterLabel}" />
                                    <TextBox x:Name="ModSearchBox"
                                             VerticalContentAlignment="Center"
                                             TextChanged="ModSearchBox_TextChanged" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                    <TextBlock Text="Status" Style="{StaticResource FilterLabel}" />
                                    <ComboBox x:Name="StatusFilterBox"
                                              SelectionChanged="StatusFilterBox_SelectionChanged" />
                                </StackPanel>

                                <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                    <TextBlock Text="Character" Style="{StaticResource FilterLabel}" />
                                    <ComboBox x:Name="CharacterFilterBox"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"
                                              StaysOpenOnEdit="True"
                                              SelectionChanged="CharacterFilterBox_SelectionChanged"
                                              DropDownClosed="CharacterFilterBox_DropDownClosed"
                                              KeyUp="CharacterFilterBox_KeyUp" />
                                </StackPanel>

                                <StackPanel Grid.Column="3">
                                    <TextBlock Text="Folder" Style="{StaticResource FilterLabel}" />
                                    <ComboBox x:Name="FolderFilterBox"
                                              IsEditable="True"
                                              IsTextSearchEnabled="True"
                                              StaysOpenOnEdit="True"
                                              SelectionChanged="FolderFilterBox_SelectionChanged"
                                              DropDownClosed="FolderFilterBox_DropDownClosed"
                                              KeyUp="FolderFilterBox_KeyUp" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource TopPanel}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="Profile and state" Style="{StaticResource PanelTitle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Profile" Style="{StaticResource FilterLabel}" />
                                    <ComboBox x:Name="ProfileBox"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Key"
                                              SelectionChanged="ProfileBox_SelectionChanged" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="DLMM state" Style="{StaticResource FilterLabel}" />
                                    <TextBlock x:Name="StatePathText"
                                               Height="30"
                                               VerticalAlignment="Center"
                                               Foreground="#9F9F9F"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border x:Name="NoticeBanner"
                DockPanel.Dock="Top"
                Background="#203125"
                BorderBrush="#5EA86A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,10"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <TextBlock x:Name="NoticeBannerText"
                       Foreground="#F5FFF2"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
        </Border>

        <Expander DockPanel.Dock="Top"
                  IsExpanded="True"
                  Margin="0,0,0,12">
            <Expander.Header>
                <TextBlock Text="Last session loadout"
                           Foreground="#F4F4F4"
                           FontSize="16"
                           FontWeight="SemiBold" />
            </Expander.Header>
            <Border Background="#1B1B1B"
                    BorderBrush="#303030"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,8,0,0"
                    Padding="12">
                <ItemsControl x:Name="LoadoutSummaryList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#242424"
                                    BorderBrush="#3B3B3B"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="10,7"
                                    Margin="0,0,8,8">
                                <StackPanel>
                                    <TextBlock Text="{Binding HeroDisplay}"
                                               Foreground="#91D18B"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ModName}"
                                               Foreground="#F2F2F2"
                                               TextWrapping="Wrap"
                                               MaxWidth="260" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </Expander>

        <ScrollViewer x:Name="MainScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel">
            <ItemsControl x:Name="HeroGroupsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="True" Margin="0,0,0,14">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayHero}"
                                               Foreground="#F4F4F4"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding Mods.Count, StringFormat='  {0} mods'}"
                                               Foreground="#BDBDBD"
                                               Margin="10,2,0,0" />
                                    <TextBlock Text="{Binding EnabledCount, StringFormat='  {0} enabled'}"
                                               Foreground="#91D18B"
                                               Margin="10,2,0,0" />
                                    <TextBlock Text="{Binding IncludedCount, StringFormat='  {0} included'}"
                                               Foreground="#D5B56E"
                                               Margin="10,2,0,0" />
                                </StackPanel>
                            </Expander.Header>

                            <Border Background="#1B1B1B"
                                    BorderBrush="#303030"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="16"
                                    Margin="0,8,0,0">
                                <Grid>
                                    <TextBlock Text="{Binding BackgroundHero}"
                                               FontSize="64"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Opacity="0.08"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Top"
                                               IsHitTestVisible="False" />

                                    <ItemsControl ItemsSource="{Binding Mods}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="210"
                                                        Height="340"
                                                        Margin="0,0,14,14"
                                                        Background="#242424"
                                                        BorderBrush="#3B3B3B"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="120" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0"
                                                                Background="#151515"
                                                                CornerRadius="8,8,0,0"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <Image Source="{Binding ImageUrl}"
                                                                       Stretch="UniformToFill"
                                                                       Opacity="0.92" />
                                                            </Grid>
                                                        </Border>

                                                        <Grid Grid.Row="1" Margin="10">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel Grid.Row="0">
                                                                <TextBlock Text="{Binding Name}"
                                                                           Foreground="#F2F2F2"
                                                                           FontWeight="SemiBold"
                                                                           TextWrapping="Wrap"
                                                                           MaxHeight="44" />
                                                                <TextBlock Text="{Binding Category}"
                                                                           Foreground="#B7B7B7"
                                                                           Margin="0,4,0,8" />
                                                                <CheckBox Content="Include in randomiser"
                                                                          IsChecked="{Binding IncludedInRandomizer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          Checked="ModPreference_Changed"
                                                                          Unchecked="ModPreference_Changed"
                                                                          Foreground="#EDEDED"
                                                                          Margin="0,0,0,4" />
                                                                <CheckBox Content="In use"
                                                                          IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          Checked="ModPreference_Changed"
                                                                          Unchecked="ModPreference_Changed"
                                                                          Foreground="#EDEDED" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="1" Margin="0,8,0,0">
                                                                <StackPanel Visibility="{Binding ShowCharacterSelector, Converter={StaticResource BoolToVisibility}}">
                                                                    <TextBlock Text="Character"
                                                                               Foreground="#AFAFAF"
                                                                               Margin="0,0,0,3" />
                                                                    <ComboBox SelectedValue="{Binding Hero, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              ItemsSource="{Binding CharacterOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              DisplayMemberPath="Name"
                                                                              SelectedValuePath="Key"
                                                                              TextSearch.TextPath="Name"
                                                                              IsEditable="False"
                                                                              IsTextSearchEnabled="True"
                                                                              SelectionChanged="CharacterSelector_SelectionChanged"
                                                                              Padding="4,2"
                                                                              Background="White"
                                                                              Foreground="#111111"
                                                                              BorderBrush="#4A4A4A" />
                                                                </StackPanel>

                                                                <StackPanel Margin="0,8,0,0"
                                                                            Visibility="{Binding ShowFolderSelector, Converter={StaticResource BoolToVisibility}}">
                                                                    <TextBlock Text="Folder"
                                                                               Foreground="#AFAFAF"
                                                                               Margin="0,0,0,3" />
                                                                    <ComboBox SelectedValue="{Binding Folder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              ItemsSource="{Binding FolderOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              DisplayMemberPath="Name"
                                                                              SelectedValuePath="Key"
                                                                              TextSearch.TextPath="Name"
                                                                              IsEditable="False"
                                                                              IsTextSearchEnabled="True"
                                                                              SelectionChanged="FolderSelector_SelectionChanged"
                                                                              Padding="4,2"
                                                                              Background="White"
                                                                              Foreground="#111111"
                                                                              BorderBrush="#4A4A4A" />
                                                                </StackPanel>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
