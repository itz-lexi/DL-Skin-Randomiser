<Window x:Class="DL_Skin_Randomiser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DL_Skin_Randomiser"
        mc:Ignorable="d"
        Title="Deadlock Skin Randomiser" Height="760" Width="1180"
        Icon="/Assets/CreatorWatermark.png"
        Background="#0F1011"
        FontFamily="Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <SolidColorBrush x:Key="AccentPinkBrush" Color="#FF7AD9" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="#B76DFF" />
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#73D7FF" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#2A2632" />
        <LinearGradientBrush x:Key="PrideAccentBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#73D7FF" Offset="0" />
            <GradientStop Color="#73D7FF" Offset="0.2" />
            <GradientStop Color="#FF7AD9" Offset="0.2" />
            <GradientStop Color="#FF7AD9" Offset="0.4" />
            <GradientStop Color="#F7F7F7" Offset="0.4" />
            <GradientStop Color="#F7F7F7" Offset="0.6" />
            <GradientStop Color="#FF7AD9" Offset="0.6" />
            <GradientStop Color="#FF7AD9" Offset="0.8" />
            <GradientStop Color="#73D7FF" Offset="0.8" />
            <GradientStop Color="#73D7FF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrideAccentHoverBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#A5E7FF" Offset="0" />
            <GradientStop Color="#FFA8E6" Offset="0.45" />
            <GradientStop Color="#D5B6FF" Offset="1" />
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PrimaryActionBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#8EDFFF" Offset="0" />
            <GradientStop Color="#FF8CDD" Offset="1" />
        </LinearGradientBrush>
        <SolidColorBrush x:Key="AccentSelectionBrush" Color="#2C2433" />
        <LinearGradientBrush x:Key="AppHeaderBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#17191B" Offset="0" />
            <GradientStop Color="#211B27" Offset="0.52" />
            <GradientStop Color="#151D23" Offset="1" />
        </LinearGradientBrush>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Background" Value="#242628" />
            <Setter Property="Foreground" Value="#F3F3F3" />
            <Setter Property="BorderBrush" Value="#3A3D40" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#303438" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource PrimaryActionBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#1F2224" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="{StaticResource AccentPinkBrush}" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryActionBrush}" />
            <Setter Property="Foreground" Value="#111111" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentPinkBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#EEF2F0" />
            <Setter Property="Background" Value="#202326" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemChrome"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="#2E2635" />
                                <Setter Property="Foreground" Value="#FFEAF8" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource AccentSelectionBrush}" />
                                <Setter Property="Foreground" Value="#FFEAF8" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True" />
                                    <Condition Property="IsHighlighted" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemChrome" Property="Background" Value="#34283D" />
                                <Setter Property="Foreground" Value="#FFEAF8" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MaxDropDownHeight" Value="280" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Background" Value="#202326" />
            <Setter Property="Foreground" Value="#EEF2F0" />
            <Setter Property="BorderBrush" Value="#3A3F43" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <ToggleButton x:Name="DropDownToggle"
                                          Grid.ColumnSpan="2"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboChrome"
                                                Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                BorderThickness="{Binding BorderThickness, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="28" />
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="1"
                                                        x:Name="ArrowHitbox"
                                                        Background="#282D31"
                                                        BorderBrush="#3A3F43"
                                                        BorderThickness="1,0,0,0"
                                                        CornerRadius="0,8,8,0">
                                                    <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                          Fill="{StaticResource AccentPinkBrush}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboChrome" Property="BorderBrush" Value="#6B747A" />
                                                <Setter TargetName="ComboChrome" Property="Background" Value="#252A2D" />
                                                <Setter TargetName="ArrowHitbox" Property="Background" Value="#32383D" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ComboChrome" Property="BorderBrush" Value="{StaticResource AccentPinkBrush}" />
                                                <Setter TargetName="ArrowHitbox" Property="Background" Value="#34283D" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <TextBlock x:Name="ContentSite"
                                       Grid.Column="0"
                                       Margin="{TemplateBinding Padding}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Left"
                                       IsHitTestVisible="False"
                                       Foreground="{TemplateBinding Foreground}"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.Text>
                                    <PriorityBinding>
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="SelectionBoxItem.Name" />
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="SelectionBoxItem" />
                                    </PriorityBinding>
                                </TextBlock.Text>
                            </TextBlock>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Grid.Column="0"
                                     Margin="{TemplateBinding Padding}"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{TemplateBinding Foreground}"
                                     Focusable="True"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     Text="{Binding Text, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Popup x:Name="PART_Popup"
                                   Grid.ColumnSpan="2"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="#202326"
                                        BorderBrush="{StaticResource AccentPinkBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer Margin="0,5"
                                                  CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="9,4" />
            <Setter Property="Background" Value="#202326" />
            <Setter Property="Foreground" Value="#EEF2F0" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentPinkBrush}" />
            <Setter Property="BorderBrush" Value="#3A3F43" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TextBoxChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="#6B747A" />
                                <Setter TargetName="TextBoxChrome" Property="Background" Value="#252A2D" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="TextBoxChrome" Property="BorderBrush" Value="{StaticResource AccentPinkBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#EDEDED" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid MinHeight="{TemplateBinding MinHeight}"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border x:Name="CheckChrome"
                                    Width="14"
                                    Height="14"
                                    Background="#F4F4F4"
                                    BorderBrush="#D8D8D8"
                                    BorderThickness="1"
                                    CornerRadius="2"
                                    VerticalAlignment="Center" />
                            <ContentPresenter Grid.Column="1"
                                              Margin="4,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckChrome" Property="Background" Value="{StaticResource PrideAccentBrush}" />
                                <Setter TargetName="CheckChrome" Property="BorderBrush" Value="{StaticResource AccentPinkBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckChrome" Property="BorderBrush" Value="{StaticResource AccentPinkBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AEB4B8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F4F4" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="TopPanel" TargetType="Border">
            <Setter Property="Background" Value="#1D2022" />
            <Setter Property="BorderBrush" Value="#34383C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="9" />
            <Setter Property="Margin" Value="0,0,8,8" />
        </Style>
        <Style TargetType="Expander">
            <Setter Property="Foreground" Value="#F4F4F4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <DockPanel>
                            <ToggleButton x:Name="HeaderToggle"
                                          DockPanel.Dock="Top"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="0"
                                          HorizontalContentAlignment="Stretch"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ExpanderHeaderChrome"
                                                Background="Transparent"
                                                BorderBrush="Transparent"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="2">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="22"
                                                        Height="22"
                                                        Background="#282D31"
                                                        BorderBrush="#3A3F43"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Margin="0,0,7,0">
                                                    <Path x:Name="ExpanderChevron"
                                                          Data="M 0 0 L 5 5 L 10 0"
                                                          Stroke="{StaticResource AccentPinkBrush}"
                                                          StrokeThickness="2"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          RenderTransformOrigin="0.5,0.5">
                                                        <Path.RenderTransform>
                                                            <RotateTransform Angle="0" />
                                                        </Path.RenderTransform>
                                                    </Path>
                                                </Border>
                                                <ContentPresenter Grid.Column="1"
                                                                  Content="{TemplateBinding Content}"
                                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                  ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ExpanderHeaderChrome" Property="Background" Value="#191C1E" />
                                                <Setter TargetName="ExpanderHeaderChrome" Property="BorderBrush" Value="#30353A" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="ExpanderChevron" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="180" />
                                                    </Setter.Value>
                                                </Setter>
                                                <Setter TargetName="ExpanderHeaderChrome" Property="BorderBrush" Value="#3F3348" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  ContentStringFormat="{TemplateBinding HeaderStringFormat}" />
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite"
                                              DockPanel.Dock="Bottom"
                                              ContentSource="Content"
                                              Visibility="Collapsed" />
                        </DockPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="InvisibleScrollButton" TargetType="RepeatButton">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ModernScrollThumb" TargetType="Thumb">
            <Setter Property="MinHeight" Value="44" />
            <Setter Property="MinWidth" Value="44" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbChrome"
                                Margin="3"
                                Background="#5B666C"
                                BorderBrush="#728087"
                                BorderThickness="1"
                                CornerRadius="6">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="8"
                                                  Direction="270"
                                                  Opacity="0.18"
                                                  ShadowDepth="1"
                                                  Color="#000000" />
                            </Border.Effect>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource PrideAccentBrush}" />
                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="{StaticResource AccentPinkBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbChrome" Property="Background" Value="{StaticResource PrideAccentHoverBrush}" />
                                <Setter TargetName="ThumbChrome" Property="BorderBrush" Value="#FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#101213" />
            <Setter Property="Width" Value="14" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Width="{TemplateBinding Width}"
                              Background="Transparent">
                            <Border Margin="4,2"
                                    Background="#1D2022"
                                    BorderBrush="#2C3135"
                                    BorderThickness="1"
                                    CornerRadius="7" />
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource InvisibleScrollButton}"
                                                  Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ModernScrollThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource InvisibleScrollButton}"
                                                  Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Width" Value="Auto" />
                    <Setter Property="Height" Value="14" />
                    <Setter Property="Margin" Value="0,8,0,0" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid Height="{TemplateBinding Height}"
                                      Background="Transparent">
                                    <Border Margin="2,4"
                                            Background="#1D2022"
                                            BorderBrush="#2C3135"
                                            BorderThickness="1"
                                            CornerRadius="7" />
                                    <Track x:Name="PART_Track"
                                           Orientation="Horizontal">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource InvisibleScrollButton}"
                                                          Command="ScrollBar.PageLeftCommand" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ModernScrollThumb}" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource InvisibleScrollButton}"
                                                          Command="ScrollBar.PageRightCommand" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="NoticeProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="3" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="1" />
            <Setter Property="Background" Value="#151819" />
            <Setter Property="Foreground" Value="{StaticResource PrideAccentBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>
    <Grid>
    <DockPanel Margin="14">
        <Border DockPanel.Dock="Top"
                Background="{StaticResource AppHeaderBrush}"
                BorderBrush="#2B2E31"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,0,0,8">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Deadlock Skin Randomiser"
                                   Foreground="#F7F7F7"
                                   FontSize="20"
                                   FontWeight="Bold" />
                        <TextBlock Text="Search, reroll, apply, play."
                                   Foreground="#9EA5AA"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Background="#201D25"
                            BorderBrush="#3F3348"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Ellipse x:Name="TrayStatusDot"
                                     Width="10"
                                     Height="10"
                                     Fill="#91D18B"
                                     VerticalAlignment="Center"
                                     Margin="0,0,10,0" />
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="NoticeTitleText"
                                           Text="Ready"
                                           Foreground="#F3F3F3"
                                           FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock x:Name="StatusText"
                                           Text="Load a profile to begin."
                                           Foreground="#AEB4B8"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <StackPanel>
                    <Border Style="{StaticResource TopPanel}" HorizontalAlignment="Left" MinWidth="390">
                        <StackPanel>
                            <WrapPanel>
                                <Button x:Name="RandomisePlayButton"
                                        Width="148"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="RandomisePlayButton_Click"
                                        Content="Randomise &amp; Play" />
                                <Button x:Name="RandomiseButton"
                                        Width="92"
                                        Click="RandomiseButton_Click"
                                        Content="Reroll" />
                                <Button x:Name="ApplyButton"
                                        Width="92"
                                        Click="ApplyButton_Click"
                                        Content="Apply" />
                                <Button x:Name="ReloadButton"
                                        Width="88"
                                        Click="ReloadButton_Click"
                                        Content="Reload" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <ToggleButton x:Name="ManageFoldersToggle"
                                  Margin="0,0,8,8"
                                  HorizontalContentAlignment="Stretch"
                                  Background="#1D2022"
                                  BorderBrush="#34383C"
                                  BorderThickness="1"
                                  Padding="10,7"
                                  Cursor="Hand">
                        <ToggleButton.Template>
                            <ControlTemplate TargetType="ToggleButton">
                                <Border x:Name="ManageToggleChrome"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8"
                                        Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="22"
                                                Height="22"
                                                Background="#282D31"
                                                BorderBrush="#3A3F43"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Margin="0,0,9,0">
                                            <Path x:Name="ManageChevron"
                                                  Data="M 0 0 L 5 5 L 10 0"
                                                  Stroke="{StaticResource AccentPinkBrush}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RenderTransformOrigin="0.5,0.5">
                                                <Path.RenderTransform>
                                                    <RotateTransform Angle="0" />
                                                </Path.RenderTransform>
                                            </Path>
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="Manage folders"
                                                   Foreground="#E7EBED"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ManageToggleChrome" Property="BorderBrush" Value="{StaticResource PrimaryActionBrush}" />
                                        <Setter TargetName="ManageToggleChrome" Property="Background" Value="#202326" />
                                    </Trigger>
                                    <Trigger Property="IsChecked" Value="True">
                                        <Setter TargetName="ManageToggleChrome" Property="BorderBrush" Value="{StaticResource AccentPinkBrush}" />
                                        <Setter TargetName="ManageChevron" Property="RenderTransform">
                                            <Setter.Value>
                                                <RotateTransform Angle="180" />
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </ToggleButton.Template>
                    </ToggleButton>
                    <Border Style="{StaticResource TopPanel}"
                            Margin="0,0,8,8"
                            Visibility="{Binding IsChecked, ElementName=ManageFoldersToggle, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <WrapPanel>
                                    <TextBlock Margin="0,0,8,8"
                                               VerticalAlignment="Center"
                                               Foreground="#AEB7BA"
                                               Text="New folder" />
                                    <TextBox x:Name="NewFolderTextBox"
                                             Width="170"
                                             Margin="0,0,8,8"
                                             VerticalContentAlignment="Center" />
                                    <Button x:Name="AddFolderButton"
                                            Width="100"
                                            Click="AddFolderButton_Click"
                                            Content="Add" />
                                    <Button x:Name="BrowseDlmmButton"
                                            Width="110"
                                            Click="BrowseDlmmButton_Click"
                                            Content="DLMM state" />
                                    <Button x:Name="BackupPreferencesButton"
                                            Width="120"
                                            Click="BackupPreferencesButton_Click"
                                            Content="Backup setup" />
                                </WrapPanel>
                                <WrapPanel Margin="0,4,0,0">
                                    <TextBlock Margin="0,0,8,8"
                                               VerticalAlignment="Center"
                                               Foreground="#AEB7BA"
                                               Text="Backups" />
                                    <ComboBox x:Name="BackupBox"
                                              Width="360"
                                              Margin="0,0,8,8"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Key" />
                                    <Button x:Name="RestoreBackupButton"
                                            Width="120"
                                            Click="RestoreBackupButton_Click"
                                            Content="Restore" />
                                </WrapPanel>
                                <WrapPanel Margin="0,4,0,0">
                                    <TextBlock Margin="0,0,8,8"
                                               VerticalAlignment="Center"
                                               Foreground="#AEB7BA"
                                               Text="Selected folder" />
                                    <ComboBox x:Name="EditFolderBox"
                                              Width="170"
                                              Margin="0,0,8,8"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Key"
                                              SelectionChanged="EditFolderBox_SelectionChanged" />
                                    <TextBox x:Name="EditFolderNameTextBox"
                                             Width="170"
                                             Margin="0,0,8,8"
                                             VerticalContentAlignment="Center" />
                                    <Button x:Name="RenameFolderButton"
                                            Width="118"
                                            Click="RenameFolderButton_Click"
                                            Content="Rename" />
                                    <Button x:Name="RemoveFolderButton"
                                            Width="118"
                                            Click="RemoveFolderButton_Click"
                                            Content="Remove" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                </StackPanel>

                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource TopPanel}">
                        <WrapPanel>
                            <StackPanel Width="260" Margin="0,0,10,0">
                                <TextBlock Text="Search mods" Style="{StaticResource FilterLabel}" />
                                <TextBox x:Name="ModSearchBox"
                                         VerticalContentAlignment="Center"
                                         TextChanged="ModSearchBox_TextChanged" />
                            </StackPanel>

                            <StackPanel Width="96" Margin="0,0,10,0">
                                <TextBlock Text="Use" Style="{StaticResource FilterLabel}" />
                                <CheckBox x:Name="InUseFilterCheckBox"
                                          Content="In use"
                                          VerticalAlignment="Center"
                                          Margin="0,6,0,0"
                                          Checked="FilterCheckBox_Changed"
                                          Unchecked="FilterCheckBox_Changed" />
                            </StackPanel>

                            <StackPanel Width="126" Margin="0,0,10,0">
                                <TextBlock Text="Randomiser" Style="{StaticResource FilterLabel}" />
                                <CheckBox x:Name="InRandomizerFilterCheckBox"
                                          Content="Included"
                                          VerticalAlignment="Center"
                                          Margin="0,6,0,0"
                                          Checked="FilterCheckBox_Changed"
                                          Unchecked="FilterCheckBox_Changed" />
                            </StackPanel>

                            <StackPanel Width="170" Margin="0,0,10,0">
                                <TextBlock Text="Character" Style="{StaticResource FilterLabel}" />
                                <ComboBox x:Name="CharacterFilterBox"
                                          IsEditable="True"
                                          IsTextSearchEnabled="True"
                                          StaysOpenOnEdit="True"
                                          SelectionChanged="CharacterFilterBox_SelectionChanged"
                                          DropDownClosed="CharacterFilterBox_DropDownClosed"
                                          KeyUp="CharacterFilterBox_KeyUp" />
                            </StackPanel>

                            <StackPanel Width="170">
                                <TextBlock Text="Folder" Style="{StaticResource FilterLabel}" />
                                <ComboBox x:Name="FolderFilterBox"
                                          IsEditable="True"
                                          IsTextSearchEnabled="True"
                                          StaysOpenOnEdit="True"
                                          SelectionChanged="FolderFilterBox_SelectionChanged"
                                          DropDownClosed="FolderFilterBox_DropDownClosed"
                                          KeyUp="FolderFilterBox_KeyUp" />
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource TopPanel}" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Profile" Style="{StaticResource FilterLabel}" />
                                    <ComboBox x:Name="ProfileBox"
                                              DisplayMemberPath="Name"
                                              SelectedValuePath="Key"
                                              SelectionChanged="ProfileBox_SelectionChanged" />
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="DLMM state" Style="{StaticResource FilterLabel}" />
                                    <TextBlock x:Name="StatePathText"
                                               Height="30"
                                               VerticalAlignment="Center"
                                               Foreground="#9F9F9F"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <Border x:Name="NoticeBanner"
                DockPanel.Dock="Top"
                Background="#203125"
                BorderBrush="#5EA86A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,10,10,8"
                Margin="0,0,0,12"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="NoticeBannerText"
                           Foreground="#F5FFF2"
                           FontSize="14"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center" />
                <Button x:Name="DismissNoticeButton"
                        Grid.Column="1"
                        Width="28"
                        MinHeight="24"
                        Margin="12,0,0,0"
                        Padding="0"
                        Content="x"
                        Click="DismissNoticeButton_Click" />
                <ProgressBar x:Name="NoticeExpiryBar"
                             Grid.Row="1"
                             Grid.ColumnSpan="2"
                             Style="{StaticResource NoticeProgress}"
                             Value="1"
                             Margin="0,9,4,0" />
            </Grid>
        </Border>

        <Expander DockPanel.Dock="Top"
                  IsExpanded="False"
                  Margin="0,0,0,12">
            <Expander.Header>
                <TextBlock Text="Last session loadout"
                           Foreground="#F4F4F4"
                           FontSize="16"
                           FontWeight="SemiBold" />
            </Expander.Header>
            <Border Background="#1B1B1B"
                    BorderBrush="#303030"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,8,0,0"
                    Padding="12">
                <StackPanel>
                    <WrapPanel Margin="0,0,0,10">
                        <TextBlock Text="Preset name"
                                   Style="{StaticResource FilterLabel}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,8" />
                        <TextBox x:Name="PresetNameTextBox"
                                 Width="180"
                                 Margin="0,0,8,8"
                                 VerticalContentAlignment="Center" />
                        <Button x:Name="SavePresetButton"
                                Width="118"
                                Click="SavePresetButton_Click"
                                Content="Save preset" />
                        <ComboBox x:Name="PresetBox"
                                  Width="280"
                                  Margin="0,0,8,8"
                                  DisplayMemberPath="Name"
                                  SelectedValuePath="Key" />
                        <Button x:Name="LoadPresetButton"
                                Width="118"
                                Click="LoadPresetButton_Click"
                                Content="Load preset" />
                    </WrapPanel>
                    <ItemsControl x:Name="LoadoutSummaryList">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#242424"
                                        BorderBrush="#3B3B3B"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="10,7"
                                        Margin="0,0,8,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding HeroDisplay}"
                                                   Foreground="#91D18B"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding ModName}"
                                                   Foreground="#F2F2F2"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="260" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </Expander>

        <Border Background="#141617"
                BorderBrush="#262A2D"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14">
            <ScrollViewer x:Name="MainScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="MainScrollViewer_PreviewMouseWheel">
                <ItemsControl x:Name="HeroGroupsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                  Expanded="HeroSection_Expanded"
                                  Collapsed="HeroSection_Collapsed"
                                  Margin="0,0,0,14">
                            <Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayHero}"
                                               Foreground="#F4F4F4"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding ModCountText}"
                                               Foreground="#BDBDBD"
                                               Margin="10,2,0,0" />
                                    <TextBlock Text="{Binding EnabledCountText}"
                                               Foreground="#91D18B"
                                               Margin="10,2,0,0" />
                                    <TextBlock Text="{Binding IncludedCountText}"
                                               Foreground="#D5B56E"
                                               Margin="10,2,0,0" />
                                </StackPanel>
                            </Expander.Header>

                            <Border Background="#1B1B1B"
                                    BorderBrush="#303030"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="0,8,0,0">
                                <Grid>
                                    <TextBlock Text="{Binding BackgroundHero}"
                                               FontSize="64"
                                               FontWeight="Bold"
                                               Foreground="White"
                                               Opacity="0.08"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Top"
                                               IsHitTestVisible="False" />

                                    <ItemsControl ItemsSource="{Binding Mods}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>

                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="188"
                                                        Height="270"
                                                        Margin="0,0,10,10"
                                                        Background="#242424"
                                                        BorderBrush="#3B3B3B"
                                                        BorderThickness="1"
                                                        CornerRadius="8">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="94" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>

                                                        <Border Grid.Row="0"
                                                                Background="#151515"
                                                                CornerRadius="8,8,0,0"
                                                                ClipToBounds="True">
                                                            <Grid>
                                                                <Image Source="{Binding ImageUrl}"
                                                                       Stretch="UniformToFill"
                                                                       Opacity="0.92" />
                                                            </Grid>
                                                        </Border>

                                                        <Grid Grid.Row="1" Margin="8">
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="*" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel Grid.Row="0">
                                                                <TextBlock Text="{Binding Name}"
                                                                           Foreground="#F2F2F2"
                                                                           FontWeight="SemiBold"
                                                                           FontSize="12"
                                                                           TextWrapping="Wrap"
                                                                           MaxHeight="36" />
                                                                <TextBlock Text="{Binding Category}"
                                                                           Foreground="#B7B7B7"
                                                                           FontSize="12"
                                                                           Margin="0,2,0,5" />
                                                                <WrapPanel Margin="0,0,0,3">
                                                                    <CheckBox Content="Randomiser"
                                                                              IsChecked="{Binding IncludedInRandomizer, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              Checked="ModPreference_Changed"
                                                                              Unchecked="ModPreference_Changed"
                                                                              Margin="0,0,10,2" />
                                                                    <CheckBox Content="In use"
                                                                              IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                              Checked="ModPreference_Changed"
                                                                              Unchecked="ModPreference_Changed"
                                                                              Margin="0,0,0,2" />
                                                                </WrapPanel>
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="1" Margin="0,5,0,0">
                                                                <TextBlock Text="Group"
                                                                           Foreground="#AFAFAF"
                                                                           FontSize="12"
                                                                           Margin="0,0,0,3" />
                                                                <ComboBox SelectedValue="{Binding AssignmentKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                          ItemsSource="{Binding GroupOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                          DisplayMemberPath="Name"
                                                                          SelectedValuePath="Key"
                                                                          TextSearch.TextPath="Name"
                                                                          IsEditable="False"
                                                                          IsTextSearchEnabled="True"
                                                                          SelectionChanged="GroupSelector_SelectionChanged"
                                                                          MinHeight="28"
                                                                          Padding="7,2" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </DockPanel>
    <Grid HorizontalAlignment="Right"
          VerticalAlignment="Bottom"
          Margin="0,0,18,18"
          Panel.ZIndex="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0"
                Background="#17191B"
                BorderBrush="{StaticResource AccentPinkBrush}"
                BorderThickness="1"
                CornerRadius="8,0,0,8"
                Padding="14,11"
                Width="275"
                Visibility="{Binding IsChecked, ElementName=CreatorOverlayToggle, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="Made by Lexi"
                           Foreground="#F4F4F4"
                           FontWeight="SemiBold"
                           FontSize="14" />
                <TextBlock Foreground="#AEB4B8"
                           FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,4,0,0">
                    <Run Text="Found a bug or have feedback? Join " />
                    <Hyperlink NavigateUri="https://discord.gg/N8JXJqtSbh"
                               RequestNavigate="DiscordLink_RequestNavigate">
                        <Run Text="discord.gg/N8JXJqtSbh" />
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>
        <ToggleButton x:Name="CreatorOverlayToggle"
                      Grid.Column="1"
                      Width="58"
                      Height="58"
                      Padding="6"
                      Background="#17191B"
                      BorderBrush="{StaticResource AccentPinkBrush}"
                      BorderThickness="1"
                      ToolTip="Creator and bug reports">
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="CreatorButtonChrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CreatorButtonChrome" Property="Background" Value="#202326" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CreatorButtonChrome" Property="CornerRadius" Value="0,8,8,0" />
                            <Setter TargetName="CreatorButtonChrome" Property="Background" Value="#202326" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ToggleButton.Template>
            <Image Source="/Assets/CreatorWatermark.png"
                   Stretch="Uniform"
                   Opacity="0.94" />
        </ToggleButton>
    </Grid>
    </Grid>
</Window>
